{
  "name": "pointflow",
  "private": true,
  "author": "Dawid Bińkowski",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @pointflow/drizzle-schemas db:generate",
    "db:migrate": "npx tsx scripts/db-migrate-all.ts",
    "db:seed": "npx tsx scripts/db-seed-all.ts",
    "simulate:user": "npx tsx scripts/simulate-user-created.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^24.x",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "kafkajs": "^2.2.4",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "2.8.14",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,md,json,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  }
}
