# Environment Variables

Copy this file to `.env` and fill in your values.

```bash
cp .env.example .env
```

# ──────────────────────────────────────────
# Database — CockroachDB v25.2
# ──────────────────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/pointflow?sslmode=disable

# ──────────────────────────────────────────
# Kafka 4.2 KRaft
# ──────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────
# Email (MailHog in dev, SMTP in production)
# ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@pointflow.dev

# ──────────────────────────────────────────
# Service ports
# ──────────────────────────────────────────
WEB_PORT=3000
API_GATEWAY_PORT=3001
LOYALTY_ENGINE_PORT=3002
AUTH_PORT=3003
ANALYTICS_PORT=3004
PORTAL_PORT=3005

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
NODE_ENV=development
