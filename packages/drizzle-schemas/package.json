{
  "name": "@pointflow/drizzle-schemas",
  "version": "0.0.0",
  "private": true,
  "author": "Dawid Bińkowski",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/seed.ts"
  },
  "dependencies": {
    "@pointflow/contracts": "workspace:*",
    "@pointflow/types": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@pointflow/typescript-config": "workspace:*",
    "@types/node": "^24.x",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
